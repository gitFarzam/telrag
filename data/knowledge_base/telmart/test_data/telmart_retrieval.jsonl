// cashier_help.txt
{"query": "TelMart Cashier Checkout Assistance", "category": "checkout_support", "file_name": "cashier_help.txt"}
{"query": "TelMart associates are available at staffed checkout lanes throughout the store to assist customers with their purchases.", "category": "checkout_support", "file_name": "cashier_help.txt"}
{"query": "Check Out With Me Service: TelMart associates can check out customers directly on the sales floor using cellular devices and Bluetooth printers.", "category": "checkout_support", "file_name": "cashier_help.txt"}
{"query": "Associates outfitted with mobile checkout devices can complete the customer's purchase and provide a receipt (paper or electronic) wherever the customer is in the store.", "category": "checkout_support", "file_name": "cashier_help.txt"}
{"query": "This service is positioned in the busiest areas of the store, such as the garden center, electronics, or action alley.", "category": "checkout_support", "file_name": "cashier_help.txt"}
{"query": "To complete a purchase at a staffed register, the customer should place their items on the conveyor belt or hand them to the cashier.", "category": "checkout_support", "file_name": "cashier_help.txt"}
{"query": "The cashier will scan each item and provide a running total.", "category": "checkout_support", "file_name": "cashier_help.txt"}
{"query": "Once all items are scanned, the customer should select their payment method.", "category": "checkout_support", "file_name": "cashier_help.txt"}
{"query": "Payment types accepted include cash, credit card, debit card, TelMart Pay, EBT/SNAP, gift cards, and other approved payment methods.", "category": "checkout_support", "file_name": "cashier_help.txt"}
{"query": "For transactions using TelMart Pay, the customer should scan the on-screen QR code to connect their account.", "category": "checkout_support", "file_name": "cashier_help.txt"}
{"query": "All TelMart policies applicable to store sales, including those regarding Ad Match, Price Matching, Coupon use, Returns, and Exchanges, apply to purchases made through TelMart Pay.", "category": "checkout_support", "file_name": "cashier_help.txt"}
{"query": "If a customer experiences any issues at the cashier lane, they should ask the associate for assistance or contact the Customer Service Desk.", "category": "checkout_support", "file_name": "cashier_help.txt"}

