{
  "name": "Telrag App",
  "dockerComposeFile": "../compose.dev.yaml",
  "service": "app",
  "workspaceFolder": "/usr/src/app",
  "shutdownAction": "stopCompose",

  // Features to install — top-level, NOT inside customizations
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "installOhMyZsh": true,
      "username": "vscode",
      "uid": "1000",
      "gid": "1000",
      "upgradePackages": true
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/src/app/venv/bin/python",
        "python.terminal.activateEnvironment": true
      }
    }
  }
}