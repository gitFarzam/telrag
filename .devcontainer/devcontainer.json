{
  "name": "Telrag App",
  "dockerComposeFile": "../compose.dev.yaml",

  //service : the-name-of-the-service-you-want-to-work-with-in-vscode 
  "service": "app", 

  //Default workspace path in container to open (like when we use exec, we can set quickly log in a specific dir, instead of using cd src/usr/...)
  "workspaceFolder": "/usr/src/app",
  "shutdownAction": "stopCompose",

  "forwardPorts": [8000],
    "portsAttributes": {
    "8000": {
      "label": "Django Backend",
      "onAutoForward": "notify"
    }
}

}